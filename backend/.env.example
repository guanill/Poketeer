# Get a free API key at https://pokemontcg.io/sign-up
# Copy this file to .env and fill in your key
POKEMON_TCG_API_KEY=your_key_here

# Roboflow card detection — get a free key at https://app.roboflow.com/settings/api-key
ROBOFLOW_API_KEY=your_key_here
ROBOFLOW_MODEL_ID=pokemon-card-detector-cuyon/1
CARD_DETECTOR_MODE=roboflow
